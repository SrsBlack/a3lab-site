# Database
DATABASE_URL=postgresql://proof_user:proof_pass@localhost:5432/proof_db
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
PORT=3001

# Storage (S3 or Cloudflare R2)
S3_BUCKET=proof-media
S3_REGION=us-east-1
S3_ENDPOINT=              # For R2: https://<account_id>.r2.cloudflarestorage.com
CDN_URL=                  # e.g. https://media.proof.social
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMS (Twilio)
SMS_PROVIDER=stub         # 'stub' for dev, 'twilio' for production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Mobile app
EXPO_PUBLIC_API_URL=http://localhost:3001

# Misc
AI_DETECTION_ENDPOINT=http://localhost:8000/detect
NODE_ENV=development
